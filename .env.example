# CoachOwl environment (copy to .env for local dev).

# --- Database ---
# Local (host) dev pointing at the docker-compose postgres on port 5434:
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5434/coachowl

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256

# --- Redis (background jobs, later waves) ---
REDIS_URL=redis://localhost:6380/0

# --- Org defaults (AU localization) ---
DEFAULT_TIMEZONE=Australia/Sydney
DEFAULT_CURRENCY=AUD
DEFAULT_GST_RATE=0.10

# --- AI (optional; not used by the foundation) ---
# ANTHROPIC_API_KEY=
